# Active Ethereum JSON-RPC endpoint.
# Local(DEPEND ON YOUR CONFIGURATION):
# RPC_URL=http://127.0.0.1:8545
# CHAIN_ID=20001209
#
# Sepolia(EXAMPLE):
# RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# CHAIN_ID=11155111
#
# Mainnet(EXAMPLE):
# RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# CHAIN_ID=1
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=20001209

# Optional account keys for public/test networks.
# For local geth, Go/Rust clients can read deploy/geth/accounts.local.example.json instead.
MASTER_PRIVATE_KEY=
